  standingSprite: {fileID: -2014518629615138023, guid: 8bf35559a0ba66e49865e9d112cf7bab, type: 3}
  fallenSprite: {fileID: 7452622166835271133, guid: 822106258f3051b41b5ad04c0ca8de47, type: 3}
  player: {fileID: 1806290727}
  triggerDistance: 3
  breakSound: {fileID: 8300000, guid: 48366341b0c24dd4cbfac46ce514875c, type: 3}
  dialogueBox: {fileID: 1559546872}
  dialogueTMP: {fileID: 225380824}
  playerNameTMP: {fileID: 1666989150}
  potDialogues:
  - playerName: Kiro
    dialogueText: 'W...what was that sound just now...? '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: 'A flower pot...? it blocked the hallway? '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: No way... the debris is everywhere
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: 'Doesn''t matter. I have to get out of here somewhere '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  globalLight: {fileID: 1578925866}
  targetIntensity: 0.02
  playerLight: {fileID: 1806290728}
  gameplayManager: {fileID: 28775278}
