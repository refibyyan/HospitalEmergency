  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 155d76c31cbef2e47ac7c7d84c9c66a2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  fadeImage: {fileID: 1339462614}
  fadeDuration: 3
  dialogueBox: {fileID: 1559546872}
  dialogueTMP: {fileID: 225380824}
  playerNameTMP: {fileID: 1666989150}
  introDialogues:
  - playerName: Kiro
    dialogueText: The lights are finally back...
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: ... That exit door
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: Staying here won't change anything
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: Alright...
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: 'I think... I finally have a moment to breathe  '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: 'Maybe I can rest for just a little while '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: At least the lights are back on now
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  globalLight: {fileID: 1578925866}
  characterLight: {fileID: 1806290728}
  playerMovementScript: {fileID: 1806290726}
