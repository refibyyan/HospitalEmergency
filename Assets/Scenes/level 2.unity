MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1198475201}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f98a8fb78dae848488c38bc6dc788fdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DoctorDialogueTrigger
  sceneIntroManager: {fileID: 2012722489}
  doctorDialogues:
  - playerName: Kiro
    dialogueText: The sound of that monitor is making me nervous
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: That patient doesn't look okay... I should check immediately
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: W-What...? The Lights went out...
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: The monitor stopped... even the lights are dead...
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Kiro
    dialogueText: What am I supposed to do in a blackout like this?
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Doctor
    dialogueText: Hey there!
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  - playerName: Doctor
    dialogueText: 'We need your help! We must save the patient! '
    textSpeed: 0.04
    textDelay: 1.4
    dialogueSFX: {fileID: 8300000, guid: bdb9a52f3bf884943a34f2a62e8c0449, type: 3}
  quickDecisionManager: {fileID: 487723349}
  playerMovementScript: {fileID: 1014859213}
